# ═══════════════════════════════════════════
# 零 · 环境变量示例
# 复制本文件为 .env 后填入你的值：
#   cp .env.example .env
# ═══════════════════════════════════════════

# === 必须配置（至少配一个 LLM Key） ===
# 主力 LLM（DeepSeek / OpenAI / 其他兼容 OpenAI 的 API）
LLM_API_KEY=sk-你的API密钥
LLM_API_URL=https://api.deepseek.com/v1/chat/completions

# === 可选配置 ===
# Agnes AI —— 免费备选模型
AGNES_API_KEY=sk-你的Agnes密钥
AGNES_API_BASE=https://apihub.agnes-ai.com

# 搜索（Tavily / DuckDuckGo）
TAVILY_API_KEY=tvly-你的密钥

# 你的称呼（Agent 在 prompt 里会用到）
OWNER_NAME=User

# 额外 Python 路径（分号分隔，用于加载你的其他项目）
# 例如：ZERO_EXTRA_PATHS=E:/project/tools/agent-system;E:/project/tools/news-factory
ZERO_EXTRA_PATHS=

# HTTP 服务
ZERO_HOST=127.0.0.1
ZERO_PORT=5052

# 会话解锁时长（秒，默认 2 小时）
ZERO_UNLOCK_SECONDS=7200
